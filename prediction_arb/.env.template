# =============================================================================
# Prediction Arbitrage Production System — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in all required values before starting.
# Lines marked [SECRET] must never be committed to version control.
# Lines marked [DEFAULT] have a safe default and are optional to override.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets Backend
# -----------------------------------------------------------------------------
# Which backend to use for loading secrets.
# Values: aws | vault | env
# [DEFAULT]
SECRET_BACKEND=aws

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL connection string (asyncpg driver).
# [SECRET] — contains credentials
DATABASE_URL=postgresql+asyncpg://arb:changeme@postgres:5432/arbdb

# -----------------------------------------------------------------------------
# Gemini API Credentials
# [SECRET] — required in live mode
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_API_SECRET=

# -----------------------------------------------------------------------------
# Kalshi API Credentials (optional — only needed for authenticated endpoints)
# [SECRET] — optional for read-only public endpoints
# -----------------------------------------------------------------------------
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# API Server Auth Token
# [SECRET] — required; used as Bearer token for all API server requests
# -----------------------------------------------------------------------------
API_SERVER_TOKEN=

# -----------------------------------------------------------------------------
# LLM API Keys (required only when MATCHER_BACKEND=openai or anthropic)
# [SECRET]
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Alerting Credentials
# [SECRET] — required when ALERT_CHANNEL=slack
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# SMTP settings — required when ALERT_CHANNEL=email
# [SECRET]
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# -----------------------------------------------------------------------------
# HashiCorp Vault (required when SECRET_BACKEND=vault)
# [SECRET]
# -----------------------------------------------------------------------------
VAULT_TOKEN=
VAULT_ADDR=https://vault.example.com

# -----------------------------------------------------------------------------
# Scan & Poll Intervals
# [DEFAULT]
# -----------------------------------------------------------------------------
SCAN_INTERVAL_SECONDS=300
PRICE_POLL_INTERVAL_SECONDS=30
MONITOR_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Trading Parameters
# [DEFAULT]
# -----------------------------------------------------------------------------
# Minimum spread percentage to consider an opportunity (0.08 = 8%)
MIN_SPREAD_PCT=0.08

# Maximum number of concurrent open positions
MAX_POSITIONS=10

# Maximum fraction of capital per single position (0.05 = 5%)
MAX_POSITION_PCT=0.05

# Total capital in USD
CAPITAL=1000.0

# Maximum portfolio drawdown before trading is suspended (0.20 = 20%)
MAX_DRAWDOWN_PCT=0.20

# Maximum actionable opportunities processed per scan cycle
MAX_OPPORTUNITIES_PER_SCAN=50

# Minimum match confidence score (0.0–1.0)
MIN_CONFIDENCE=0.70

# Maximum risk score allowed (0.0–1.0)
MAX_RISK=0.80

# Maximum age of an orderbook snapshot before it is considered stale (seconds)
MAX_PRICE_AGE_SECONDS=60

# Minimum USD depth on Gemini ask side required to enter a position
MIN_GEMINI_DEPTH_USD=50.0

# Days to resolution threshold for convergence exit strategy
CONVERGENCE_EXIT_DAYS=7

# Price convergence threshold for early exit (in price units, e.g. 0.02 = 2¢)
CONVERGENCE_THRESHOLD=0.02

# Stop-loss threshold (price movement against position before forced exit)
STOP_LOSS_PCT=0.15

# Fee per contract in USD (currently 0 on Gemini Predictions)
FEE_PER_CONTRACT=0.0

# -----------------------------------------------------------------------------
# Execution Mode
# [DEFAULT]
# -----------------------------------------------------------------------------
# Set to false to enable live trading (real orders will be placed on Gemini)
DRY_RUN=true

# -----------------------------------------------------------------------------
# Event Matcher
# [DEFAULT]
# -----------------------------------------------------------------------------
# Backend for event matching: rule_based | openai | anthropic
MATCHER_BACKEND=rule_based

# TTL for matcher cache entries (seconds)
MATCHER_CACHE_TTL=3600

# Maximum concurrent LLM calls per batch
MAX_CONCURRENT_LLM_CALLS=5

# -----------------------------------------------------------------------------
# WebSocket Streaming (optional)
# [DEFAULT]
# -----------------------------------------------------------------------------
KALSHI_WS_ENABLED=false
POLYMARKET_WS_ENABLED=false

# -----------------------------------------------------------------------------
# API Server
# [DEFAULT]
# -----------------------------------------------------------------------------
API_SERVER_ENABLED=true
API_SERVER_PORT=8000

# CORS allowed origin for the dashboard
DASHBOARD_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Alerting
# [DEFAULT]
# -----------------------------------------------------------------------------
# Alert channel: none | slack | email | webhook
ALERT_CHANNEL=none

# Spread percentage that triggers an alert (0.20 = 20%)
ALERT_SPREAD_THRESHOLD=0.20

# Deduplication window for alerts (seconds)
ALERT_DEDUP_WINDOW=300

# -----------------------------------------------------------------------------
# Logging
# [DEFAULT]
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
